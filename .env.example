# =============================================================================
# Epstein Full — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# HuggingFace token (for authenticated downloads, higher rate limits)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub token (for gh CLI, repo creation)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxx

# GPU configuration (comma-separated device IDs)
# 0 = Tesla K80 (first), 1 = Tesla K80 (second), 2 = Tesla K40m
CUDA_VISIBLE_DEVICES=0,1,2

# Data paths (override defaults if needed)
DATA_DIR=/mnt/data/epstein-project
RAW_DIR=/mnt/data/epstein-project/raw-files
DB_DIR=/mnt/data/epstein-project/databases
HF_DIR=/mnt/data/epstein-project/hf-parquet
LOG_DIR=/mnt/data/epstein-project/logs
PROCESSED_DIR=/mnt/data/epstein-project/processed
KG_DIR=/mnt/data/epstein-project/knowledge-graph

# Download configuration
CDN_BASE_URL=https://media-cdn.rollcall.com/epstein-files
ARIA2_CONNECTIONS=10
ARIA2_MAX_CONCURRENT=16

# Processing configuration
OCR_BACKEND=surya                  # pytorch, surya, docling
OCR_WORKERS=4
NER_MODEL=en_core_web_trf          # en_core_web_sm (faster) or en_core_web_trf (better)
WHISPER_MODEL=large-v3             # tiny, base, small, medium, large-v3
EMBEDDING_MODEL=nomic-embed-text-v2-moe

# SQLite configuration
DB_TIMEOUT=10
DB_WAL_MODE=true
