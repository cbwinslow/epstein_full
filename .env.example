# =============================================================================
# Epstein Full — Environment Variables
# =============================================================================
# NEVER commit this file to git (it's in .gitignore).
# =============================================================================

# HuggingFace token
HF_TOKEN=your_huggingface_token_here

# GitHub token
GITHUB_TOKEN=your_github_token_here

# GPU configuration
# Tesla K40m (GPU 0, CC 3.5) — TOO OLD for PyTorch, use ONNX only
# Tesla K80 (GPU 1, CC 3.7) — WORKS with PyTorch 2.3.1+cu118
# Tesla K80 (GPU 2, CC 3.7) — WORKS with PyTorch 2.3.1+cu118
CUDA_VISIBLE_DEVICES=1,2

# Data paths
DATA_DIR=/path/to/epstein-project
RAW_DIR=/path/to/epstein-project/raw-files
DB_DIR=/path/to/epstein-project/databases
HF_DIR=/path/to/epstein-project/hf-parquet
LOG_DIR=/path/to/epstein-project/logs

# Download config
CDN_BASE_URL=https://media-cdn.rollcall.com/epstein-files
ARIA2_CONNECTIONS=10

# Processing config
OCR_BACKEND=surya
NER_MODEL=en_core_web_trf
WHISPER_MODEL=large-v3

# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_postgres_user
PG_PASSWORD=your_postgres_password
PG_DBNAME=epstein
FEC_API_KEY=your_fec_api_key_here

# Government Data API Keys
GOVINFO_API_KEY=your_govinfo_api_key_here
CONGRESS_API_KEY=your_congress_api_key_here
